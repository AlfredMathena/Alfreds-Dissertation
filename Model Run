        "\n",
        "    accuracy = correct / total\n",
        "    print(f\"Epoch {epoch+1} | Loss: {total_loss/len(train_loader):.4f} | Val Acc: {accuracy:.4f}\")\n",
        "\n",
        "    # Early Stopping Logic\n",
        "    if accuracy > best_accuracy:\n",
